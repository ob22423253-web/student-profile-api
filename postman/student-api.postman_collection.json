{
  "info": {
    "name": "Student Profile API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "REST API for managing student profiles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "studentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "API info",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api", "host": ["{{baseUrl}}"], "path": ["api"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Students CRUD",
      "item": [
        {
          "name": "Create student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"age\": 28,\n  \"course\": \"Computer Science\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/students", "host": ["{{baseUrl}}"], "path": ["api", "students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('studentId', body._id);",
                  "pm.test('has _id', () => pm.expect(body).to.have.property('_id'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('has pagination', () => pm.expect(pm.response.json()).to.have.property('pagination'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Search students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students?q=ada",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students"],
              "query": [{ "key": "q", "value": "ada" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status is 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get student by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status is 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update student",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course\": \"Data Science\",\n  \"age\": 29\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status is 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete student",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('has message', () => pm.expect(pm.response.json().message).to.eql('Student deleted'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Statistics",
      "item": [
        {
          "name": "Get stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "stats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has total', () => pm.expect(body).to.have.property('total'));",
                  "pm.test('has byCourse', () => pm.expect(body.byCourse).to.be.an('array'));",
                  "pm.test('has recentlyRegistered', () => pm.expect(body).to.have.property('recentlyRegistered'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
